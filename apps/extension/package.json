{
    "name": "@shiba/extension",
    "description": "Cute tab manager and custom homepage",
    "private": true,
    "version": "0.1.0",
    "author": {
        "name": "Justin Chung",
        "url": "https://github.com/justin13888/"
    },
    "homepage": "https://github.com/justin13888/shiba",
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "typecheck": "wxt prepare && tsc --noEmit",
        "test": "vitest run",
        "postinstall": "wxt prepare"
    },
    "dependencies": {
        "@kobalte/core": "^0.13.4",
        "@shiba/core": "workspace:*",
        "@shiba/crdt-yjs": "workspace:*",
        "@shiba/crypto-webcrypto": "workspace:*",
        "@shiba/storage-idb": "workspace:*",
        "@solid-primitives/storage": "^4.2.1",
        "@solidjs/router": "^0.14.1",
        "@tanstack/solid-virtual": "^3.8.3",
        "@webext-core/messaging": "^2.1.0",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "lucide-solid": "^0.411.0",
        "nanoid": "^5.0.7",
        "solid-js": "^1.9.0",
        "solid-motionone": "^1.0.2",
        "tailwind-merge": "^2.4.0",
        "tailwindcss-animate": "^1.0.7",
        "valibot": "^1.0.0"
    },
    "devDependencies": {
        "@solidjs/testing-library": "^0.8.10",
        "@testing-library/jest-dom": "^6.6.3",
        "@types/webextension-polyfill": "^0.10.7",
        "@wxt-dev/module-solid": "^1.1.4",
        "autoprefixer": "^10.4.19",
        "jsdom": "^25.0.1",
        "postcss": "^8.4.39",
        "tailwindcss": "^3.4.6",
        "typescript": "^5.7.3",
        "vitest": "^3.0.0",
        "wxt": "^0.19.29"
    }
}
