{
    "name": "@shiba/extension",
    "description": "Cute tab manager and custom homepage",
    "private": true,
    "version": "0.1.0",
    "author": {
        "name": "Justin Chung",
        "url": "https://github.com/justin13888/"
    },
    "homepage": "https://github.com/justin13888/shiba",
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "typecheck": "wxt prepare && tsc --noEmit",
        "postinstall": "wxt prepare"
    },
    "dependencies": {
        "@kobalte/core": "^0.13.4",
        "@solid-primitives/storage": "^4.2.1",
        "@solidjs/meta": "^0.29.4",
        "@solidjs/router": "^0.14.1",
        "@tanstack/solid-query": "^5.59.13",
        "@tanstack/solid-query-devtools": "^5.59.16",
        "@tanstack/solid-virtual": "^3.8.3",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "idb": "^8.0.0",
        "lodash": "^4.17.21",
        "lucide-solid": "^0.411.0",
        "nanoid": "^5.0.7",
        "solid-js": "^1.8.18",
        "solid-motionone": "^1.0.2",
        "tailwind-merge": "^2.4.0",
        "tailwindcss-animate": "^1.0.7"
    },
    "devDependencies": {
        "@types/lodash": "^4.17.13",
        "@types/webextension-polyfill": "^0.10.7",
        "@wxt-dev/module-solid": "^1.1.1",
        "autoprefixer": "^10.4.19",
        "postcss": "^8.4.39",
        "tailwindcss": "^3.4.6",
        "typescript": "^5.7.3",
        "wxt": "^0.19.29"
    }
