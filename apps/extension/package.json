{
    "name": "@shiba/extension",
    "description": "Cute tab manager and custom homepage",
    "private": true,
    "version": "0.1.0",
    "author": {
        "name": "Justin Chung",
        "url": "https://github.com/justin13888/"
    },
    "homepage": "https://github.com/justin13888/shiba",
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "typecheck": "wxt prepare && tsc --noEmit",
        "test": "vitest run",
        "postinstall": "wxt prepare"
    },
    "dependencies": {
        "@kobalte/core": "^0.13.11",
        "@shiba/core": "workspace:*",
        "@shiba/crdt-yjs": "workspace:*",
        "@shiba/crypto-webcrypto": "workspace:*",
        "@shiba/storage-idb": "workspace:*",
        "@shiba/sync-protocol": "workspace:*",
        "@solid-primitives/storage": "^4.3.4",
        "@solidjs/router": "^0.16.1",
        "@tanstack/solid-virtual": "^3.13.29",
        "@webext-core/messaging": "^3.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.4.0",
        "lucide-solid": "^1.21.0",
        "nanoid": "^5.1.15",
        "solid-js": "^1.9.13",
        "solid-motionone": "^1.0.4",
        "tailwind-merge": "^3.6.0",
        "tailwindcss-animate": "^1.0.7",
        "valibot": "^1.4.1"
    },
    "devDependencies": {
        "@solidjs/testing-library": "^0.8.10",
        "@testing-library/jest-dom": "^6.9.1",
        "@types/webextension-polyfill": "^0.12.5",
        "@wxt-dev/module-solid": "^1.1.4",
        "autoprefixer": "^10.4.19",
        "jsdom": "^29.1.1",
        "postcss": "^8.5.15",
        "tailwindcss": "^3.4.6",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9",
        "wxt": "^0.20.26"
    }
}
