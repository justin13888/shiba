{
    "name": "shiba",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=22"
    },
    "packageManager": "bun@1.3.13",
    "workspaces": [
        "packages/*",
        "adapters/*",
        "apps/*"
    ],
    "trustedDependencies": [
        "better-sqlite3",
        "esbuild"
    ],
    "scripts": {
        "build": "bun run --filter '*' build",
        "typecheck": "bun run --filter '*' typecheck",
        "test": "bun run --filter '*' test",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write ."
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "typescript": "^6.0.3"
    }
}
